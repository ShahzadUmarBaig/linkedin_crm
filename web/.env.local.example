# Supabase — get these from your Supabase project's API settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: service role key (NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the Chrome extension uses to authenticate ingest requests.
# Generate one with: openssl rand -hex 32
EXTENSION_INGEST_SECRET=

# App key used to encrypt user-supplied Claude/Gemini API keys at rest.
# Generate one with: openssl rand -hex 32  (must be 64 hex chars = 32 bytes)
APP_ENCRYPTION_KEY=
